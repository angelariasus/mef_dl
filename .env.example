# ─── API MEF ──────────────────────────────────────────────────────────────────
MEF_API_BASE_URL=https://api.datosabiertos.mef.gob.pe/DatosAbiertos/v1
MEF_YEARS=2022,2023,2024
MEF_BATCH_SIZE=10000

# ─── Rutas locales ───────────────────────────────────────────────────────────
MEF_BRONZE_DIR=data/bronze
MEF_SILVER_DIR=data/silver
MEF_GOLD_DIR=data/gold
MEF_STATE_FILE=data/.state.json

# ─── Spark ───────────────────────────────────────────────────────────────────
MEF_SPARK_MASTER=local[*]
MEF_SPARK_APP_NAME=MEF_Pipeline_v2
